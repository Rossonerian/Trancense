# Data mode. demo is always available; supabase requires the server variables below.
DATA_MODE=supabase

# Supabase project values. The service-role key is server-only and must never be NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Connect dialog: transaction pooler for app/CLI, direct connection for migrations.
DATABASE_URL=
DIRECT_URL=

# AI is optional. demo is deterministic and never calls an external provider.
AI_PROVIDER=auto
OPENROUTER_API_KEY=
# Leave blank for runtime catalogue discovery, or set a comma-separated verified free chain.
OPENROUTER_MODEL_CHAIN=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Trancense
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
