# Production must use supabase. demo is only for explicit local development.
DATA_MODE=supabase
NEXT_PUBLIC_APP_URL=https://trancense.vercel.app

# Vercel Supabase integration names. Public URL/key are browser-safe; service role is server-only.
NEXT_PUBLIC_STORAGE_SUPABASE_URL=
NEXT_PUBLIC_STORAGE_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STORAGE_SUPABASE_PUBLISHABLE_KEY=
STORAGE_SUPABASE_SERVICE_ROLE_KEY=

# Local-development aliases also supported by the resolver.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Connect dialog: transaction pooler for app/CLI, direct connection for migrations.
DATABASE_URL=
DIRECT_URL=

# AI is optional. demo is deterministic and never calls an external provider.
AI_PROVIDER=auto
OPENROUTER_API_KEY=
# Leave blank for runtime catalogue discovery, or set a comma-separated verified free chain.
OPENROUTER_MODEL_CHAIN=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Trancense
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
